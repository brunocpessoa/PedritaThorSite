---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina nao encontrada" description="A pagina que voce tentou acessar nao foi encontrada.">
  <section class="band">
    <div class="container narrow notice-card">
      <h1>Pagina nao encontrada</h1>
      <p>O conteudo pode ter mudado de lugar. Volte para o inicio e continue navegando pela Pedrita & Thor.</p>
      <a class="button button--primary" href="/">Voltar ao inicio</a>
    </div>
  </section>
</BaseLayout>
